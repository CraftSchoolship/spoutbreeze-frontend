NEXT_PUBLIC_API_URL=

# Stripe (for future Stripe Elements integration)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Firebase (Authentication + Push Notifications)
# Copy these from the Firebase Console → Project settings → "Your apps" (Web app).
# They are public by design (shipped to the browser).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# VAPID key is only needed for FCM push notifications (Cloud Messaging → Web Push certificates).
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
